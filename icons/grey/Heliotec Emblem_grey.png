    (function() {
      function applySquarespaceEnhancements() {
        // 1. Apply section background images from data-current-styles JSON
        document.querySelectorAll('[data-current-styles]').forEach(function(el) {
          try {
            var raw = el.getAttribute('data-current-styles');
            if (!raw) return;
            var data = JSON.parse(raw);
            var bg = data.backgroundImage;
            if (!bg || !bg.assetUrl) return;
            // Check if section-background already has an <img> or CSS background (handled inline)
            var bgDiv = el.querySelector('.section-background');
            if (bgDiv && (bgDiv.querySelector('img[src]') || bgDiv.style.background)) return;
            if (!bgDiv) return;
            // Prefer local file: try /images/{filename-stem}.webp then .png then CDN URL
            var filename = bg.filename || '';
            var stem = filename.replace(/\.[^.]+$/, '');
            var candidates = stem ? ['/images/' + stem + '.webp', '/images/' + stem + '.png', '/images/' + filename] : [];
            var cdnUrl = bg.assetUrl + (bg.assetUrl.indexOf('?') === -1 ? '?format=2500w' : '');
            // Try local candidates first, fall back to CDN
            (function tryNext(i) {
              var url = i < candidates.length ? candidates[i] : cdnUrl;
              if (i >= candidates.length) {
                injectBgImg(bgDiv, url, data);
              } else {
                var probe = new Image();
                probe.onload = function() { injectBgImg(bgDiv, url, data); };
                probe.onerror = function() { tryNext(i + 1); };
                probe.src = url;
              }
            })(0);
          } catch(e) {}
        });
        function injectBgImg(bgDiv, url, data) {
          if (bgDiv.querySelector('img')) return;
          var img = document.createElement('img');
          img.src = url;
          img.alt = '';
          img.style.cssText = 'display:block;pointer-events:none;';
          bgDiv.appendChild(img);
          var overlay = data.imageOverlayOpacity;
          if (overlay) {
            var section = bgDiv.closest('section') || bgDiv.parentElement;
            if (section && !section.querySelector('.background-image-overlay')) {
              var div = document.createElement('div');
              div.className = 'background-image-overlay';
              div.style.cssText = 'position:absolute;inset:0;background:rgba(0,0,0,' + overlay + ');pointer-events:none;z-index:1;';
              section.insertBefore(div, section.querySelector('.content-wrapper'));
            }
          }
        }

        // 2. Convert data-src → src for lazy-loaded images
        document.querySelectorAll('img[data-src]').forEach(function(img) {
          if (!img.src || img.src === window.location.href) {
            img.src = img.dataset.src;
          }
        });

        // 3. Apply noscript fallback images
        document.querySelectorAll('noscript').forEach(function(ns) {
          var html = ns.innerHTML;
          if (html.indexOf('<img') >= 0) {
            var tmp = document.createElement('div');
            tmp.innerHTML = html;
            var img = tmp.querySelector('img');
            if (img) ns.parentNode.insertBefore(img, ns);
          }
        });
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', applySquarespaceEnhancements);
      } else {
        applySquarespaceEnhancements();
      }
      // Also run after site-bundle may have initialized
      window.addEventListener('load', applySquarespaceEnhancements);
    })();
  </script> <!-- Start of HubSpot Embed Code --> <script type="text/javascript" id="hs-script-loader" async defer src="//js-eu1.hs-scripts.com/49378762.js"></script> <!-- End of HubSpot Embed Code --> </body></html>