Close navigation menu" data-astro-cid-3ef6ksr2>&#x2715;</button> <nav aria-label="Mobile Navigation" data-astro-cid-3ef6ksr2> <a href="/solutions" data-astro-cid-3ef6ksr2>Solutions</a> <a href="/platform" data-astro-cid-3ef6ksr2>Platform</a> <a href="/sectors" data-astro-cid-3ef6ksr2>Sectors</a> <a href="/pricing" data-astro-cid-3ef6ksr2>Pricing</a> <a href="/news" data-astro-cid-3ef6ksr2>News</a> </nav> <div class="hlt-mob-actions" data-astro-cid-3ef6ksr2> <a href="https://app.heliotec.energy/client/login/" class="hlt-mob-login" target="_blank" rel="noopener" data-astro-cid-3ef6ksr2>Log in</a> <a href="#contactForm" class="hlt-mob-cta hlt-mob-cta--primary" data-astro-cid-3ef6ksr2>Try for free</a> <a href="https://www.heliotec.energy/book-20min-demo" class="hlt-mob-cta hlt-mob-cta--secondary" target="_blank" rel="noopener" data-astro-cid-3ef6ksr2>Schedule demo</a> </div> </div>  <script>
  (function() {
    var bar     = document.getElementById('hltMobBar');
    var overlay = document.getElementById('hltMobOverlay');
    var burger  = document.getElementById('hltMobBurger');
    var closeBtn = document.getElementById('hltMobClose');
    if (!bar || !overlay || !burger) return;

    function openMenu() {
      overlay.setAttribute('aria-hidden', 'false');
      overlay.style.display = 'flex';
      burger.setAttribute('aria-expanded', 'true');
      document.body.style.overflow = 'hidden';
    }
    function closeMenu() {
      overlay.setAttribute('aria-hidden', 'true');
      overlay.style.display = 'none';
      burger.setAttribute('aria-expanded', 'false');
      document.body.style.overflow = '';
    }

    burger.addEventListener('click', function() {
      overlay.style.display === 'flex' ? closeMenu() : openMenu();
    });

    if (closeBtn) closeBtn.addEventListener('click', closeMenu);

    overlay.querySelectorAll('nav a').forEach(function(link) {
      link.addEventListener('click', closeMenu);
    });

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape') closeMenu();
    });
  })();
</script> <div class="page-content-wrapper"> <div class="squarespace-content" data-astro-cid-kib2vhrf><main class="container" id="page" role="main">
